# ---------------------------------------------------------------------------
# governed-omop-rag — variables d'environnement (copier en .env, ne pas commit).
# Toutes ont un défaut raisonnable dans config.py ; ce fichier documente l'usage.
# ---------------------------------------------------------------------------

# Environnement applicatif : "dev" | "test" | "prod"
GOR_ENV=dev

# Niveau de log : DEBUG | INFO | WARNING | ERROR
GOR_LOG_LEVEL=INFO

# --- LLM des agents (Phase 3) : Claude ---
# Clé API Anthropic (NE JAMAIS committer une vraie clé).
GOR_ANTHROPIC_API_KEY=
GOR_LLM_MODEL=claude-sonnet-5

# --- Base vectorielle (Phase 1-2) : Qdrant par défaut (souverain) ---
GOR_VECTOR_BACKEND=qdrant
GOR_QDRANT_URL=http://localhost:6333
GOR_QDRANT_API_KEY=
GOR_QDRANT_COLLECTION=ohdsi_concepts

# --- Embeddings biomédicaux locaux (Phase 1) ---
# Backend : sentence_transformers (BioLORD réel) ou hashing (offline déterministe)
GOR_EMBEDDING_BACKEND=sentence_transformers
GOR_EMBEDDING_MODEL=FremyCompany/BioLORD-2023
GOR_EMBEDDING_DEVICE=cpu
GOR_EMBEDDING_DIM=256

# --- Corpus médaillon (couche data) ---
GOR_DATA_DIR=data
GOR_DUCKDB_PATH=data/gor.duckdb

# --- Router déterministe : alignement officiel CIM-10 <-> SNOMED-CT (ATIH) ---
GOR_ROUTER_MAP_PATH=data/router/cim10_snomed_official.csv

# --- Évaluation : gold set (vérité terrain) ---
GOR_GOLD_SET_PATH=data/eval/gold_set.csv

# --- Cache de retrieval : memory (non persistant) ou duckdb (persistant) ---
GOR_CACHE_BACKEND=duckdb
GOR_CACHE_PATH=data/cache.duckdb

# --- Feedback steward (journal des décisions, amélioration continue) ---
GOR_FEEDBACK_PATH=data/steward_feedback.duckdb

# --- Garde-fous / gouvernance ---
# Seuil de confiance minimal en dessous duquel on renvoie concept_id = 0.
GOR_CONFIDENCE_THRESHOLD=0.5
# Nombre de candidats top-k injectés dans le prompt de l'agent Proposer.
GOR_TOP_K=10
# Porte d'abstention de l'agent : marge de retrieval (score top-1 − top-2) en deçà
# de laquelle l'entrée est jugée ambiguë -> abstention (concept_id=0), sans appel LLM.
# 0.0 = désactivé (défaut). Valeur recommandée en production : 0.005 (cf. docs/evaluation.md).
GOR_AGENT_MIN_MARGIN=0.0

# --- Garde de coût de l'API (accès PUBLIC volontaire : pas d'authentification pour
# la démo, mais on borne le coût/abus ; l'auth sera ajoutée plus tard) ---
# Quota par IP : au plus MAX requêtes par fenêtre glissante de WINDOW secondes
# (0 = désactivé). Défaut restrictif : 3 par jour (86400 s). Chaque mapping peut
# coûter un appel LLM. NB : compteur en mémoire (reset au redémarrage, non
# partagé entre réplicas) ; une IP partagée (NAT) partage son quota.
GOR_API_RATE_LIMIT_MAX=3
GOR_API_RATE_LIMIT_WINDOW_SECONDS=86400
# Taille maximale d'un lot /map/batch (au-delà : HTTP 413).
GOR_API_MAX_BATCH_SIZE=50
